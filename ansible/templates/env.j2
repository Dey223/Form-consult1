# ============================================================
# env.j2 — Template du fichier .env pour la production
# ============================================================
# Ce fichier est un TEMPLATE Jinja2.
# Ansible remplace les {{ variables }} par les vraies valeurs
# au moment du déploiement.
#
# ⚠️ NE JAMAIS committer un vrai .env avec des secrets réels.
#    Ce fichier contient des placeholders → les vraies valeurs
#    sont dans ansible/group_vars/formconsult.yml (non commité)
#    ou passées en ligne de commande avec --extra-vars
# ============================================================

# Base de données (Docker Compose résout "db" vers le conteneur PostgreSQL)
DATABASE_URL="postgresql://formconsult:formconsult123@db:5432/formconsult"

# NextAuth — Authentification
# NEXTAUTH_URL doit pointer vers l'IP publique du serveur en production
NEXTAUTH_URL="http://{{ server_ip }}:3000"
NEXTAUTH_SECRET="{{ nextauth_secret }}"

# Services externes (laisser vide = fonctionnalités désactivées)
# Stripe — paiements
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="{{ stripe_publishable_key | default('') }}"
STRIPE_SECRET_KEY="{{ stripe_secret_key | default('') }}"
STRIPE_WEBHOOK_SECRET="{{ stripe_webhook_secret | default('') }}"

# Mux — vidéos
MUX_TOKEN_ID="{{ mux_token_id | default('') }}"
MUX_TOKEN_SECRET="{{ mux_token_secret | default('') }}"

# UploadThing — upload de fichiers
UPLOADTHING_TOKEN="{{ uploadthing_token | default('') }}"
